/* 全局样式 */
page {
  background: linear-gradient(180deg, #FFF5F0 0%, #FFF8F3 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #2D3748;
}

/* 主色调 - 火焰橙 */
.primary-color {
  color: #FF6B35;
}

.bg-primary {
  background: linear-gradient(135deg, #FF6B35 0%, #F7931E 100%);
}

/* 次要色调 - 深蓝（对手色） */
.secondary-color {
  color: #1E3A8A;
}

.bg-secondary {
  background: linear-gradient(135deg, #1E3A8A 0%, #3B82F6 100%);
}

/* 成功色 */
.success-color {
  color: #10B981;
}

/* 警告色 */
.warning-color {
  color: #FFC107;
}

/* 危险色 */
.danger-color {
  color: #FF5252;
}

/* 容器 */
.container {
  padding: 30rpx;
}

.card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 按钮 */
.btn {
  padding: 24rpx 48rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  transition: all 0.3s;
}

.btn-primary {
  background: linear-gradient(135deg, #FF6B35 0%, #F7931E 100%);
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.3);
}

.btn-secondary {
  background: white;
  color: #FF6B35;
  border: 2rpx solid #FF6B35;
}

.btn-danger {
  background: linear-gradient(135deg, #FF5252 0%, #FF1744 100%);
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(255, 82, 82, 0.3);
}

.btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* 文本 */
.title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.text-small {
  font-size: 24rpx;
  color: #999;
}

.text-center {
  text-align: center;
}

/* Flex布局 */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

/* 血条样式 */
.health-bar-container {
  height: 60rpx;
  background: #E0E0E0;
  border-radius: 30rpx;
  overflow: hidden;
  position: relative;
}

.health-bar-fill {
  height: 100%;
  background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 100%);
  border-radius: 30rpx;
  transition: width 0.5s ease;
}

.health-bar-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: white;
  font-weight: bold;
  font-size: 24rpx;
}

/* 打卡条目样式 */
.checkin-item {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.checkin-item.checked {
  background: #F0F9F4;
}

.checkin-item.unchecked {
  background: #FFF3E0;
}

/* 状态标签 */
.status-tag {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.status-success {
  background: #E8F5E9;
  color: #4CAF50;
}

.status-warning {
  background: #FFF3E0;
  color: #FF9800;
}

.status-error {
  background: #FFEBEE;
  color: #F44336;
}

/* 输入框 */
.input {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #E0E0E0;
  border-radius: 12rpx;
  font-size: 28rpx;
  background: white;
}

.input:focus {
  border-color: #3B82F6;
}

/* 开关 */
.switch {
  transform: scale(0.9);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #999;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

/* 加载中 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  color: #999;
}

/* 模态框 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  width: 80%;
  max-width: 600rpx;
}

/* 动画 */
@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
}

.pulse {
  animation: pulse 2s ease-in-out infinite;
}
