/* pages/stats/stats.wxss */
.container {
  min-height: 100vh;
  background: #F5F5F5;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  color: #999;
}

/* Tab 切换 */
.tabs {
  display: flex;
  background: white;
  border-bottom: 1px solid #E0E0E0;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #FF6B35;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #FF6B35 0%, #F7931E 100%);
  border-radius: 2rpx;
}

/* 内容区 */
.tab-content {
  padding: 20rpx;
}

/* 统计卡片 */
.stats-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

/* 完成率对比 */
.rate-compare {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.rate-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.rate-info {
  flex: 1;
}

.name {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.rate-bar {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.bar-bg {
  flex: 1;
  height: 16rpx;
  background: #E0E0E0;
  border-radius: 8rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.bar-fill.mine {
  background: linear-gradient(90deg, #FF6B35 0%, #F7931E 100%);
}

.bar-fill.partner {
  background: linear-gradient(90deg, #1E3A8A 0%, #3B82F6 100%);
}

.rate-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #FF6B35;
  min-width: 80rpx;
  text-align: right;
}

.rate-item.partner .rate-text {
  color: #3B82F6;
}

/* 详细数据 */
.detail-stats {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.stats-row {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.stats-label {
  font-size: 26rpx;
  color: #666;
}

.stats-values {
  display: flex;
  justify-content: space-around;
  padding: 20rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.stat-value.success {
  color: #10B981;
}

.stat-value.error {
  color: #EF4444;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* 趋势图表占位 */
.trend-chart {
  min-height: 300rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.chart-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  color: #999;
}

.placeholder-icon {
  font-size: 80rpx;
}

.placeholder-text {
  font-size: 24rpx;
}

/* 历史记录 */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.period-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.period-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1px solid #F0F0F0;
}

.period-date {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.period-status {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  background: #E0E0E0;
  color: #666;
}

.period-status.completed {
  background: #DBEAFE;
  color: #1E40AF;
}

.period-status.active {
  background: #FEF3C7;
  color: #92400E;
}

.period-stats {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.period-user {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 15rpx;
  flex: 1;
}

.small-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
}

.period-data {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5rpx;
}

.data-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.data-label {
  font-size: 22rpx;
  color: #999;
}

.vs-divider {
  font-size: 24rpx;
  font-weight: bold;
  color: #999;
  padding: 0 20rpx;
}

.period-result {
  text-align: center;
  padding: 15rpx;
  background: linear-gradient(135deg, #FFF7ED 0%, #FFEDD5 100%);
  border-radius: 12rpx;
}

.result-text {
  font-size: 26rpx;
  color: #EA580C;
  font-weight: bold;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  gap: 20rpx;
}

.empty-icon {
  font-size: 100rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
