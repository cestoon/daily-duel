<!-- pages/index/index.wxml -->
<view class="container">
  <!-- 产品介绍页 -->
  <view class="welcome-page">
    <!-- Logo和名称 -->
    <view class="header">
      <view class="logo-placeholder">💪</view>
      <text class="app-name">Daily Duel</text>
      <text class="app-slogan">诀窍就在于坚持</text>
      <text class="app-slogan-en">Insistency is the key</text>
    </view>

    <!-- 功能介绍 -->
    <view class="features">
      <view class="feature-item">
        <text class="feature-icon">📝</text>
        <view class="feature-content">
          <text class="feature-title">每日打卡</text>
          <text class="feature-desc">设定目标，坚持打卡</text>
        </view>
      </view>

      <view class="feature-item">
        <text class="feature-icon">⚔️</text>
        <view class="feature-content">
          <text class="feature-title">PK对战</text>
          <text class="feature-desc">和伙伴一起PK，互相监督</text>
        </view>
      </view>

      <view class="feature-item">
        <text class="feature-icon">🏆</text>
        <view class="feature-content">
          <text class="feature-title">周结算</text>
          <text class="feature-desc">每周结算，输的请客</text>
        </view>
      </view>

      <view class="feature-item">
        <text class="feature-icon">📊</text>
        <view class="feature-content">
          <text class="feature-title">数据统计</text>
          <text class="feature-desc">记录成长，见证进步</text>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="actions">
      <button class="btn btn-primary" bindtap="showLoginModal">
        开始使用
      </button>
      <view class="hint">
        <text class="hint-icon">💡</text>
        <text class="hint-text">使用前需要登录并绑定伙伴</text>
      </view>
    </view>

    <!-- 底部说明 -->
    <view class="footer">
      <text class="footer-text">和伙伴一起打卡PK，共同进步</text>
    </view>
  </view>

</view>

<!-- 登录授权弹窗 -->
<view class="login-modal" wx:if="{{showLogin}}" catchtap="hideLoginModal">
  <view class="login-modal-content" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">授权登录</text>
      <text class="modal-close" bindtap="hideLoginModal">✕</text>
    </view>

    <view class="modal-body">
      <view class="modal-logo-placeholder">💪</view>
      <text class="modal-title-text">完善个人资料</text>
      <text class="modal-hint">用于伙伴识别，让打卡更有趣</text>
      
      <!-- 头像选择 -->
      <view class="profile-item">
        <text class="profile-label">头像</text>
        <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image class="avatar-img" src="{{avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill"></image>
          <view class="avatar-mask">
            <text class="avatar-text">{{avatarUrl ? '点击更换' : '点击选择'}}</text>
          </view>
        </button>
      </view>

      <!-- 昵称输入 -->
      <view class="profile-item">
        <text class="profile-label">昵称</text>
        <input 
          class="nickname-input" 
          type="nickname" 
          placeholder="请输入昵称"
          value="{{nickName}}"
          bindinput="onNicknameInput"
          maxlength="10"
        />
      </view>
    </view>

    <view class="modal-footer">
      <button class="btn btn-secondary" bindtap="hideLoginModal">
        取消
      </button>
      <button 
        class="btn btn-primary" 
        bindtap="handleLogin" 
        disabled="{{logining || !avatarUrl || !nickName}}"
      >
        {{logining ? '登录中...' : '完成'}}
      </button>
    </view>
  </view>
</view>
