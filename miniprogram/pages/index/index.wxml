<!-- pages/index/index.wxml -->
<view class="container">
  <!-- 产品介绍页 -->
  <view class="welcome-page">
    <!-- Logo和名称 -->
    <view class="header">
      <view class="logo-placeholder">💪</view>
      <text class="app-name">Daily Duel</text>
      <text class="app-slogan">一起打卡PK，一起变更好</text>
    </view>

    <!-- 功能介绍 -->
    <view class="features">
      <view class="feature-item">
        <text class="feature-icon">📝</text>
        <view class="feature-content">
          <text class="feature-title">每日打卡</text>
          <text class="feature-desc">设定目标，坚持打卡</text>
        </view>
      </view>

      <view class="feature-item">
        <text class="feature-icon">⚔️</text>
        <view class="feature-content">
          <text class="feature-title">PK对战</text>
          <text class="feature-desc">和伙伴一起PK，互相监督</text>
        </view>
      </view>

      <view class="feature-item">
        <text class="feature-icon">🏆</text>
        <view class="feature-content">
          <text class="feature-title">周结算</text>
          <text class="feature-desc">每周结算，输的请客</text>
        </view>
      </view>

      <view class="feature-item">
        <text class="feature-icon">📊</text>
        <view class="feature-content">
          <text class="feature-title">数据统计</text>
          <text class="feature-desc">记录成长，见证进步</text>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="actions">
      <button class="btn btn-primary" bindtap="showLoginModal">
        开始使用
      </button>
      <view class="hint">
        <text class="hint-icon">💡</text>
        <text class="hint-text">使用前需要登录并绑定伙伴</text>
      </view>
    </view>

    <!-- 底部说明 -->
    <view class="footer">
      <text class="footer-text">和伙伴一起打卡PK，共同进步</text>
    </view>
  </view>

</view>

<!-- 登录授权弹窗 -->
<view class="login-modal" wx:if="{{showLogin}}" catchtap="hideLoginModal">
  <view class="login-modal-content" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">授权登录</text>
      <text class="modal-close" bindtap="hideLoginModal">✕</text>
    </view>

    <view class="modal-body">
      <view class="modal-logo-placeholder">💪</view>
      <text class="modal-desc">需要获取您的昵称和头像</text>
      <text class="modal-hint">用于完善个人资料和伙伴识别</text>
    </view>

    <view class="modal-footer">
      <button class="btn btn-secondary" bindtap="hideLoginModal">
        取消
      </button>
      <button class="btn btn-primary" bindtap="handleLogin" disabled="{{logining}}">
        {{logining ? '登录中...' : '授权登录'}}
      </button>
    </view>
  </view>
</view>
