/* pages/index/index.wxss */
.login-container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FF6B35 0%, #F7931E 100%);
  position: relative;
  overflow: hidden;
}

.login-container::before {
  content: '';
  position: absolute;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
  animation: pulse 3s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 0.5; }
  50% { transform: scale(1.1); opacity: 0.8; }
}

.login-box {
  width: 80%;
  max-width: 600rpx;
  padding: 80rpx 40rpx;
  background: white;
  border-radius: 30rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 40rpx;
}

.app-name {
  font-size: 56rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.app-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 80rpx;
}

.btn {
  width: 100%;
  margin-bottom: 20rpx;
}

.tips {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
}

.tip-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #999;
}

.welcome-container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FFF5F0 0%, #FFE8DC 100%);
}

.welcome-box {
  width: 80%;
  max-width: 600rpx;
  padding: 80rpx 40rpx;
  background: white;
  border-radius: 30rpx;
  box-shadow: 0 20rpx 60rpx rgba(255, 107, 53, 0.15);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-box,
.welcome-box {
  position: relative;
  z-index: 1;
}

.avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  margin-bottom: 40rpx;
  border: 6rpx solid #FF6B35;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.3);
}

.welcome-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.partner-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 60rpx;
}
