/* pages/index/index.wxss */
.login-container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FF6B81 0%, #FFA07A 100%);
}

.login-box {
  width: 80%;
  max-width: 600rpx;
  padding: 80rpx 40rpx;
  background: white;
  border-radius: 30rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 40rpx;
}

.app-name {
  font-size: 56rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.app-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 80rpx;
}

.btn {
  width: 100%;
  margin-bottom: 20rpx;
}

.tips {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
}

.tip-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #999;
}

.welcome-container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FFE5E7 0%, #FFF5E6 100%);
}

.welcome-box {
  width: 80%;
  max-width: 600rpx;
  padding: 80rpx 40rpx;
  background: white;
  border-radius: 30rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  margin-bottom: 40rpx;
  border: 6rpx solid #FF6B81;
}

.welcome-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.partner-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 60rpx;
}
