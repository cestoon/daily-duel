/* pages/index/index.wxss */

/* ========== 未登录：产品介绍页 ========== */
.welcome-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #FFF5F0 0%, #FFE8DC 100%);
  padding: 60rpx 40rpx 100rpx;
  display: flex;
  flex-direction: column;
}

/* Logo区域 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo-placeholder {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 30rpx;
  font-size: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FF6B35 0%, #F7931E 100%);
  border-radius: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.3);
}

.app-name {
  font-size: 56rpx;
  font-weight: bold;
  color: #1E3A8A;
  margin-bottom: 16rpx;
}

.app-slogan {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.app-slogan-en {
  font-size: 24rpx;
  color: #999;
  font-style: italic;
  margin-bottom: 60rpx;
}

/* 功能列表 */
.features {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  margin-bottom: 60rpx;
}

.feature-item {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.feature-icon {
  font-size: 72rpx;
  margin-right: 30rpx;
}

.feature-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.feature-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 26rpx;
  color: #999;
}

/* 操作按钮 */
.actions {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.btn {
  width: 100%;
}

.hint {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 30rpx;
}

.hint-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.hint-text {
  font-size: 24rpx;
  color: #999;
}

/* 底部说明 */
.footer {
  margin-top: 40rpx;
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: #999;
}

/* ========== 登录弹窗 ========== */
.login-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.login-modal-content {
  width: 85%;
  max-width: 600rpx;
  background: white;
  border-radius: 30rpx;
  overflow: hidden;
}

.modal-header {
  padding: 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
  padding: 0 10rpx;
}

.modal-body {
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-logo-placeholder {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 30rpx;
  font-size: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FF6B35 0%, #F7931E 100%);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.3);
}

.modal-desc {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.modal-title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin: 20rpx 0 12rpx;
}

.modal-hint {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-bottom: 40rpx;
}

/* 头像昵称填写 - 优化版 */
.profile-item {
  width: 100%;
  margin-bottom: 32rpx;
}

.profile-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.avatar-btn {
  width: 140rpx;
  height: 140rpx;
  margin: 0 auto;
  padding: 0;
  background: none;
  border: none;
  position: relative;
  display: block;
  border-radius: 50%;
  overflow: hidden;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 3rpx solid #FF6B35;
  display: block;
}

.avatar-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  color: white;
  font-size: 20rpx;
}

.nickname-input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #E0E0E0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: #FAFAFA;
  box-sizing: border-box;
  transition: all 0.3s;
}

.nickname-input:focus {
  border-color: #FF6B35;
  background: white;
}

.modal-footer {
  padding: 30rpx 40rpx 40rpx;
  display: flex;
  gap: 20rpx;
}

.modal-footer .btn {
  flex: 1;
}


