/* pages/index/index.wxss */

/* ========== 未登录：产品介绍页 ========== */
.welcome-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #FFF5F0 0%, #FFE8DC 100%);
  padding: 60rpx 40rpx 100rpx;
  display: flex;
  flex-direction: column;
}

/* Logo区域 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 30rpx;
}

.app-name {
  font-size: 56rpx;
  font-weight: bold;
  color: #1E3A8A;
  margin-bottom: 16rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: #666;
}

/* 功能列表 */
.features {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  margin-bottom: 60rpx;
}

.feature-item {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.feature-icon {
  font-size: 72rpx;
  margin-right: 30rpx;
}

.feature-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.feature-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 26rpx;
  color: #999;
}

/* 操作按钮 */
.actions {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.btn {
  width: 100%;
}

.hint {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 30rpx;
}

.hint-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.hint-text {
  font-size: 24rpx;
  color: #999;
}

/* 底部说明 */
.footer {
  margin-top: 40rpx;
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: #999;
}

/* ========== 登录弹窗 ========== */
.login-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.login-modal-content {
  width: 85%;
  max-width: 600rpx;
  background: white;
  border-radius: 30rpx;
  overflow: hidden;
}

.modal-header {
  padding: 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
  padding: 0 10rpx;
}

.modal-body {
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-logo {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 30rpx;
}

.modal-desc {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.modal-hint {
  font-size: 26rpx;
  color: #999;
  text-align: center;
}

.modal-footer {
  padding: 30rpx 40rpx 40rpx;
  display: flex;
  gap: 20rpx;
}

.modal-footer .btn {
  flex: 1;
}


