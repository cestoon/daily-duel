/* pages/checkin/checkin.wxss */
.date-selector {
  background: white;
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.date-nav {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F5F5;
  border-radius: 30rpx;
  font-size: 32rpx;
  color: #666;
}

.date-nav[disabled] {
  opacity: 0.3;
}

.date-display {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.date-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.date-label {
  font-size: 24rpx;
  color: #FF6B35;
  margin-top: 8rpx;
}

.checkin-list {
  min-height: calc(100vh - 400rpx);
}

.checkin-item {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: all 0.3s;
}

.checkin-item.completed {
  background: #F0F9F4;
  border: 2rpx solid #4CAF50;
}

.checkin-item.missed {
  background: #FFF3F3;
  border: 2rpx solid #F44336;
  opacity: 0.85;
}

.checkin-item.pending {
  background: white;
  border: 2rpx solid #E0E0E0;
}

.item-left {
  flex: 1;
  display: flex;
  align-items: center;
}

.check-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 3rpx solid #E0E0E0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 36rpx;
  color: #E0E0E0;
  transition: all 0.3s;
}

.check-icon.completed {
  background: #4CAF50;
  border-color: #4CAF50;
  color: white;
}

.check-icon.missed {
  background: #F44336;
  border-color: #F44336;
  color: white;
  font-weight: bold;
}

.check-icon.pending {
  border-color: #E0E0E0;
  color: #E0E0E0;
}

.item-info {
  flex: 1;
}

.item-title {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.item-title.missed-title {
  color: #999;
  text-decoration: line-through;
}

.item-meta {
  font-size: 24rpx;
  color: #999;
}

.status-tag {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.status-tag.completed {
  background: #E8F5E9;
  color: #4CAF50;
}

.status-tag.pending {
  background: #FFF3E0;
  color: #FF9800;
}

.status-tag.missed {
  background: #FFEBEE;
  color: #F44336;
}

.status-tag.no-record {
  background: #F5F5F5;
  color: #999;
}

.empty-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
  margin-bottom: 40rpx;
}
