<!-- pages/checkin/checkin.wxml -->
<view class="container">
  <!-- 日期选择 -->
  <view class="date-selector flex-between">
    <view class="date-nav" bindtap="changeDate" data-type="prev">
      <text>◀</text>
    </view>
    <view class="date-display">
      <text class="date-text">{{currentDate}}</text>
      <text class="date-label" wx:if="{{isToday}}">今天</text>
    </view>
    <view class="date-nav" bindtap="changeDate" data-type="next" disabled="{{isToday}}">
      <text>▶</text>
    </view>
  </view>

  <!-- 打卡列表 -->
  <view class="checkin-list">
    <view wx:for="{{items}}" wx:key="_id" class="checkin-item {{item.checked ? 'checked' : ''}}" bindtap="handleCheckin" data-id="{{item._id}}">
      <view class="item-left flex">
        <view class="check-icon {{item.checked ? 'checked' : ''}}">
          <text>{{item.checked ? '✓' : '○'}}</text>
        </view>
        <view class="item-info">
          <text class="item-title">{{item.title}}</text>
          <text class="item-meta">{{item.time}} • {{item.points}}分</text>
        </view>
      </view>
      <view class="item-right">
        <view class="status-tag {{item.status}}">{{item.statusText}}</view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{items.length === 0 && !loading}}">
      <text class="empty-icon">📝</text>
      <text class="empty-text">还没有打卡条目</text>
      <button class="btn btn-primary" bindtap="goToItems">添加条目</button>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 添加按钮 -->
  <view class="add-button" bindtap="showAddModal">
    <text>+</text>
  </view>
</view>

<!-- 添加条目弹窗 -->
<view class="modal" wx:if="{{showModal}}" catchtap="hideModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-title">添加打卡条目</view>
    <view class="form-item">
      <text class="form-label">条目标题</text>
      <input class="input" placeholder="如：晨跑、读书" value="{{newItem.title}}" bindinput="onTitleInput" />
    </view>
    <view class="form-item">
      <text class="form-label">分数</text>
      <input class="input" type="number" placeholder="1" value="{{newItem.points}}" bindinput="onPointsInput" />
    </view>
    <view class="form-item">
      <text class="form-label">打卡时间</text>
      <picker mode="time" value="{{newItem.time}}" bindchange="onTimeChange">
        <view class="picker-value">{{newItem.time}}</view>
      </picker>
    </view>
    <view class="modal-actions flex-between">
      <button class="btn btn-secondary" bindtap="hideModal">取消</button>
      <button class="btn btn-primary" bindtap="addItem">确定</button>
    </view>
  </view>
</view>
