<!-- pages/settlement/settlement.wxml -->
<view class="container">
  <!-- 结算列表 -->
  <view class="settlement-list">
    <view wx:for="{{settlements}}" wx:key="_id" class="settlement-card">
      <view class="card-header flex-between">
        <view class="period-info">
          <text class="period-date">{{item.periodDate}}</text>
          <text class="status-tag {{item.status}}">{{item.statusText}}</text>
        </view>
        <view class="settlement-amount">
          <text class="amount-value">{{item.amount}}</text>
          <text class="amount-unit">积分</text>
        </view>
      </view>

      <view class="card-body">
        <view class="settlement-users flex-between">
          <view class="user-role {{item.payerId === userId ? 'payer' : 'payee'}}">
            <image class="user-avatar" src="{{item.payer.avatarUrl}}" mode="aspectFill"></image>
            <text class="user-name">{{item.payer.nickName}}</text>
            <text class="role-label">付款方</text>
          </view>
          <view class="arrow">→</view>
          <view class="user-role {{item.payeeId === userId ? 'payee' : 'payer'}}">
            <image class="user-avatar" src="{{item.payee.avatarUrl}}" mode="aspectFill"></image>
            <text class="user-name">{{item.payee.nickName}}</text>
            <text class="role-label">收款方</text>
          </view>
        </view>

        <view class="settlement-status">
          <view class="status-item">
            <text class="status-label">付款方确认</text>
            <text class="status-value {{item.payerConfirmed ? 'success' : 'warning'}}">
              {{item.payerConfirmed ? '已确认' : '未确认'}}
            </text>
          </view>
          <view class="status-item">
            <text class="status-label">收款方确认</text>
            <text class="status-value {{item.payeeConfirmed ? 'success' : 'warning'}}">
              {{item.payeeConfirmed ? '已确认' : '未确认'}}
            </text>
          </view>
        </view>

        <view class="settlement-actions" wx:if="{{item.status === 'pending'}}">
          <!-- 我是付款方 -->
          <button
            wx:if="{{item.payerId === userId}}"
            class="btn btn-primary {{item.payerConfirmed ? 'disabled' : ''}}"
            bindtap="confirmPayment"
            data-id="{{item._id}}"
            disabled="{{item.payerConfirmed}}"
          >
            {{item.payerConfirmed ? '已确认付款' : '确认已付款'}}
          </button>
          
          <!-- 我是收款方 -->
          <button
            wx:if="{{item.payeeId === userId}}"
            class="btn btn-primary {{item.payeeConfirmed ? 'disabled' : ''}}"
            bindtap="confirmPayment"
            data-id="{{item._id}}"
            disabled="{{item.payeeConfirmed}}"
          >
            {{item.payeeConfirmed ? '已确认收款' : '确认已收款'}}
          </button>
        </view>

        <view class="settlement-time" wx:if="{{item.completedAt}}">
          <text class="text-small">完成时间: {{item.completedAt}}</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{settlements.length === 0 && !loading}}">
      <text class="empty-icon">💰</text>
      <text class="empty-text">还没有结算记录</text>
      <text class="empty-desc">每周一自动结算上周PK结果</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
